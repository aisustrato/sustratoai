"use server";

import { createSupabaseServerClient } from "@/lib/server";
import { estimateTokens } from "@/lib/utils/token-estimator";

export interface ResultadoOperacion<T = void> {
	success: boolean;
	data?: T;
	error?: string;
}

// ─── Tipos ────────────────────────────────────────────────────────────────────

export type GardenElementType = "seed" | "discipline" | "theory" | "thinker";

export interface GardenElement {
	id: string;
	garden_id: string;
	element_type: GardenElementType;
	element_id: string | null;
	element_content: string | null;
	element_label: string;
	added_at: string;
}

export interface ResonanceGarden {
	id: string;
	project_id: string;
	created_by: string;
	name: string;
	description: string | null;
	emoji: string;
	created_at: string;
	updated_at: string;
	elements?: GardenElement[];
	artifacts_count?: number;
}

export interface CreateGardenInput {
	projectId: string;
	name: string;
	description?: string;
	emoji?: string;
	elements: Array<{
		element_type: GardenElementType;
		element_id?: string;
		element_content?: string;
		element_label: string;
	}>;
}

export interface GardenArtifact {
	id: string;
	title: string;
	type: string;
	status: string | null;
	created_at: string | null;
	has_chronicle: boolean;
	has_chat: boolean;
	micelio_destilada?: string;
	matched_elements: string[];
	relevance_score: number;
}

export interface GardenTokenBreakdown {
	transcripcion: number;
	elementos_cognitivos: number;
	metabolizacion_micelio: number;
	chat_calibrador: number;
	total: number;
	artifacts_procesados: number;
	artifacts_totales: number;
}

// ─── Listar jardines del proyecto ─────────────────────────────────────────────

export async function getGardensForProject(
	projectId: string,
): Promise<ResultadoOperacion<ResonanceGarden[]>> {
	try {
		const supabase = await createSupabaseServerClient();

		const { data: gardens, error } = await supabase
			.from("cog_resonance_gardens")
			.select("*")
			.eq("project_id", projectId)
			.order("created_at", { ascending: false });

		if (error) return { success: false, error: error.message };

		if (!gardens || gardens.length === 0) {
			return { success: true, data: [] };
		}

		const gardenIds = gardens.map((g: { id: string }) => g.id);

		const { data: elements } = await supabase
			.from("cog_garden_elements")
			.select("*")
			.in("garden_id", gardenIds);

		const elementsMap = new Map<string, GardenElement[]>();
		((elements as any) || []).forEach((el: GardenElement) => {
			const list = elementsMap.get(el.garden_id) || [];
			list.push(el);
			elementsMap.set(el.garden_id, list);
		});

		const result: ResonanceGarden[] = (gardens as any).map(
			(g: ResonanceGarden) => ({
				...g,
				elements: elementsMap.get(g.id) || [],
			}),
		);

		return { success: true, data: result };
	} catch (error) {
		console.error("❌ Error en getGardensForProject:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Obtener un jardín con sus elementos ─────────────────────────────────────

export async function getGardenById(
	gardenId: string,
): Promise<ResultadoOperacion<ResonanceGarden>> {
	try {
		const supabase = await createSupabaseServerClient();

		const { data: garden, error } = await supabase
			.from("cog_resonance_gardens")
			.select("*")
			.eq("id", gardenId)
			.single();

		if (error) return { success: false, error: error.message };
		if (!garden) return { success: false, error: "Jardín no encontrado" };

		const { data: elements, error: elementsError } = await supabase
			.from("cog_garden_elements")
			.select("*")
			.eq("garden_id", gardenId)
			.order("added_at", { ascending: true });

		console.log("🔍 [getGardenById] Elements query:", {
			gardenId,
			elements,
			elementsError,
		});

		return {
			success: true,
			data: { ...garden, elements: (elements as any) || [] } as any,
		};
	} catch (error) {
		console.error("❌ Error en getGardenById:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Crear jardín ─────────────────────────────────────────────────────────────

export async function createGarden(
	input: CreateGardenInput,
): Promise<ResultadoOperacion<ResonanceGarden>> {
	try {
		console.log("🌱 [createGarden] Iniciando creación:", {
			projectId: input.projectId,
			name: input.name,
			elementsCount: input.elements.length,
		});

		const supabase = await createSupabaseServerClient();

		const {
			data: { user },
		} = await supabase.auth.getUser();
		if (!user) return { success: false, error: "No autenticado" };

		const { data: garden, error: gardenError } = await supabase
			.from("cog_resonance_gardens")
			.insert({
				project_id: input.projectId,
				created_by: user.id,
				name: input.name.trim(),
				description: input.description?.trim() || null,
				emoji: input.emoji || "🌱",
			})
			.select()
			.single();

		if (gardenError) return { success: false, error: gardenError.message };
		if (!garden) return { success: false, error: "Error creando jardín" };

		console.log("✅ [createGarden] Jardín creado:", garden.id);

		if (input.elements.length > 0) {
			console.log(
				"🌱 [createGarden] Procesando elementos:",
				input.elements.length,
			);
			console.log("🌱 [createGarden] Elements input:", input.elements);
			const elementsToInsert = input.elements.map((el) => ({
				garden_id: garden.id,
				project_id: garden.project_id, // Agregar project_id para RLS
				element_type: el.element_type,
				element_id: el.element_id || null,
				element_content: el.element_content || null,
				element_label: el.element_label,
			}));

			console.log(
				"🌱 [createGarden] Insertando elementos:",
				elementsToInsert.length,
			);
			console.log("🌱 [createGarden] Elements to insert:", elementsToInsert);

			const { data: insertedElements, error: elementsError } = await supabase
				.from("cog_garden_elements")
				.insert(elementsToInsert)
				.select();

			console.log("🔍 [createGarden] Insert result:", {
				insertedElements,
				elementsError,
			});

			if (elementsError) {
				console.error(
					"❌ Error insertando elementos del jardín:",
					elementsError,
				);
				// No fallamos la creación del jardín, pero reportamos el error
				return {
					success: true,
					data: { ...garden, elements: [] } as any, // Retornar jardín sin elementos
					warning: `Jardín creado pero hubo error al insertar elementos: ${elementsError.message}`,
				} as any;
			}
			console.log(
				"✅ [createGarden] Elementos insertados correctamente:",
				insertedElements?.length || 0,
			);
		} else {
			console.log("⚠️ [createGarden] No hay elementos para insertar");
		}

		console.log("🔍 [createGarden] Obteniendo jardín completo...");
		const fullGarden = await getGardenById(garden.id);
		console.log("🔍 [createGarden] Full garden result:", fullGarden);
		return fullGarden;
	} catch (error) {
		console.error("❌ Error en createGarden:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Actualizar jardín (nombre, descripción, emoji) ──────────────────────────

export async function updateGarden(
	gardenId: string,
	updates: { name?: string; description?: string; emoji?: string },
): Promise<ResultadoOperacion<ResonanceGarden>> {
	try {
		const supabase = await createSupabaseServerClient();

		const { error } = await supabase
			.from("cog_resonance_gardens")
			.update({
				...(updates.name !== undefined && { name: updates.name.trim() }),
				...(updates.description !== undefined && {
					description: updates.description.trim() || null,
				}),
				...(updates.emoji !== undefined && { emoji: updates.emoji }),
			})
			.eq("id", gardenId);

		if (error) return { success: false, error: error.message };

		return getGardenById(gardenId);
	} catch (error) {
		console.error("❌ Error en updateGarden:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Eliminar jardín ──────────────────────────────────────────────────────────

export async function deleteGarden(
	gardenId: string,
): Promise<ResultadoOperacion> {
	try {
		const supabase = await createSupabaseServerClient();

		const { error } = await supabase
			.from("cog_resonance_gardens")
			.delete()
			.eq("id", gardenId);

		if (error) return { success: false, error: error.message };
		return { success: true };
	} catch (error) {
		console.error("❌ Error en deleteGarden:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Agregar elemento al jardín ───────────────────────────────────────────────

export async function addElementToGarden(
	gardenId: string,
	element: {
		element_type: GardenElementType;
		element_id?: string;
		element_content?: string;
		element_label: string;
	},
): Promise<ResultadoOperacion<GardenElement>> {
	try {
		const supabase = await createSupabaseServerClient();

		// 🔑 Obtener project_id del jardín para RLS (igual que en createGarden)
		const { data: garden, error: gardenError } = await supabase
			.from("cog_resonance_gardens")
			.select("project_id")
			.eq("id", gardenId)
			.single();

		if (gardenError || !garden) {
			return { success: false, error: "Jardín no encontrado" };
		}

		const { data, error } = await supabase
			.from("cog_garden_elements")
			.insert({
				garden_id: gardenId,
				project_id: garden.project_id, // 🔑 Agregar project_id para RLS
				element_type: element.element_type,
				element_id: element.element_id || null,
				element_content: element.element_content || null,
				element_label: element.element_label,
			})
			.select()
			.single();

		if (error) return { success: false, error: error.message };
		return { success: true, data: data as any };
	} catch (error) {
		console.error("❌ Error en addElementToGarden:", error);
		return {
			success: false,
			error: error instanceof Error ? error.message : "Error desconocido",
		};
	}
}

// ─── Quitar elemento del jardín ───────────────────────────────────────────────

